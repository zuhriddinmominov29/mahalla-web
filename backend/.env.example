# ============================================================
# MAHALLA TIZIMI — BACKEND SOZLAMALARI
# ============================================================

# MongoDB Atlas ulanish manzili
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/mahalla

# JWT maxfiy kalit (murakkab qiling!)
JWT_SECRET=mahalla-super-secret-key-2026

# Server porti
PORT=3001

# Setup kalit (birinchi ishga tushirishda)
SETUP_KEY=setup-mahalla-2026

# ============================================================
# CLOUDINARY — Rasm saqlash (bepul 25 GB)
# https://cloudinary.com — ro'yxatdan o'ting, Dashboard > API Keys
# ============================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================================
# WEB PUSH — Bildirishnomalar
# Kalitlarni olish uchun: npm run gen-vapid
# ============================================================
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=admin@mahalla.uz

# Frontend manzili
FRONTEND_URL=https://mahalla-tizimi.netlify.app
