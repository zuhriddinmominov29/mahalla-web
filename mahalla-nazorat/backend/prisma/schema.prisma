// Mahalla Nazorat - PostgreSQL Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  HOKIM
  DEPUTY
  RAIS
}

enum TaskType {
  PERMANENT
  ONE_TIME
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReportStatus {
  SUBMITTED
  REVIEWED
  APPROVED
  REJECTED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         Role      @default(RAIS)
  phone        String?
  avatar       String?
  district     String?
  mahalla      String?
  address      String?
  deputyField  String?
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdTasks  Task[]         @relation("CreatedTasks")
  assignedTasks Task[]         @relation("AssignedTasks")
  reports       Report[]
  notifications Notification[]

  @@map("users")
}

model Category {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  color        String   @default("#3B82F6")
  icon         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks        Task[]
  dailyConfigs DailyConfig[]

  @@map("categories")
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  type         TaskType
  status       TaskStatus @default(PENDING)
  priority     Priority   @default(MEDIUM)
  deadline     DateTime?
  completedAt  DateTime?
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id])
  assignedToId String?
  assignedTo   User?      @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User       @relation("CreatedTasks", fields: [createdById], references: [id])
  district     String?
  mahalla      String?
  deputyField  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  reports       Report[]
  notifications Notification[]

  @@map("tasks")
}

model Report {
  id           String       @id @default(cuid())
  taskId       String
  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  description  String
  status       ReportStatus @default(SUBMITTED)
  latitude     Float?
  longitude    Float?
  locationName String?
  images       String[]     @default([])
  reviewNote   String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("reports")
}

model DailyConfig {
  id         String   @id @default(cuid())
  date       DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  order      Int      @default(1)
  createdAt  DateTime @default(now())

  @@unique([date, order])
  @@map("daily_configs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  createdAt DateTime @default(now())

  @@map("notifications")
}
